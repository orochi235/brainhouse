{
  "name": "brainhouse",
  "version": "0.0.1",
  "private": true,
  "description": "React+Node port of pensieve — local web monitor for Claude Code sessions",
  "type": "module",
  "bin": {
    "brainhouse": "bin/brainhouse.js"
  },
  "files": [
    "bin",
    "hooks",
    "server/dist",
    "server/package.json"
  ],
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "dev": "run-p dev:server dev:client",
    "build:client": "npm run build -w client",
    "build:server": "npm run build -w server",
    "build": "npm run build:server && npm run build:client",
    "build:watch:client": "npm run build:watch -w client",
    "build:watch:server": "npm run build:watch -w server",
    "build:watch": "run-p build:watch:server build:watch:client",
    "start": "node server/dist/index.js",
    "serve": "npm run serve -w server",
    "check": "biome check && biome lint",
    "fix": "biome check --write && biome lint --write",
    "test:server": "npm run test -w server",
    "test:client": "npm run test -w client",
    "test": "npm run test:server && npm run test:client"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "npm-run-all": "^4.1.5"
  }
}
